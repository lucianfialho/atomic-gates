new file mode 100644
index 0000000..feb7a36
--- /dev/null
+++ b/.claude/plugins/analytics-copilot/hooks/validate-chart.py
@@ -0,0 +1,124 @@
+#!/usr/bin/env python3
+"""PreToolUse hook: validate json-render chart configs before Write/Edit.
+
+Receives tool input on stdin as JSON. Checks if the content contains a
+json-render code block and validates the component type and required props.
+
+Exit codes:
+  0 — allow (valid chart or non-chart content)
+  2 — block with error message on stderr
+"""
+import json
+import re
+import sys
+
+VALID_TYPES = {"Grid", "MetricCard", "LineChart", "BarChart", "PieChart", "AreaChart"}
+
+REQUIRED_PROPS = {
+    "MetricCard": ["label", "value"],
+    "LineChart": ["data", "xKey", "lines"],
+    "BarChart": ["data", "xKey", "bars"],
+    "PieChart": ["data"],
+    "AreaChart": ["data", "xKey", "areas"],
+    "Grid": ["children"],
+}
+
+
+def extract_json_render_blocks(text):
+    """Find all ```json-render ... ``` blocks in text."""
+    return re.findall(r"```json-render\s*\n(.*?)```", text, re.DOTALL)
+
+
+def validate_component(node, path="root"):
+    """Recursively validate a json-render component tree."""
+    errors = []
+
+    if not isinstance(node, dict):
+        errors.append(f"{path}: expected object, got {type(node).__name__}")
+        return errors
+
+    comp_type = node.get("type")
+    if not comp_type:
+        errors.append(f"{path}: missing 'type' field")
+        return errors
+
+    if comp_type not in VALID_TYPES:
+        errors.append(
+            f"{path}: unknown type '{comp_type}'. "
+            f"Valid types: {', '.join(sorted(VALID_TYPES))}"
+        )
+        return errors
+
+    props = node.get("props", {})
+    if not isinstance(props, dict):
+        errors.append(f"{path}: 'props' must be an object")
+        return errors
+
+    # Check required props
+    for req in REQUIRED_PROPS.get(comp_type, []):
+        if req == "children":
+            # children is a top-level key, not inside props
+            if not node.get("children"):
+                errors.append(f"{path} ({comp_type}): missing 'children' array")
+        elif req not in props:
+            errors.append(f"{path} ({comp_type}): missing required prop '{req}'")
+
+    # Validate data arrays are not empty
+    if "data" in props:
+        data = props["data"]
+        if isinstance(data, list) and len(data) == 0:
+            errors.append(f"{path} ({comp_type}): 'data' array must not be empty")
+
+    # Validate PieChart data items have name and value
+    if comp_type == "PieChart" and isinstance(props.get("data"), list):
+        for i, item in enumerate(props["data"]):
+            if isinstance(item, dict):
+                if "name" not in item:
+                    errors.append(f"{path}.data[{i}]: PieChart item missing 'name'")
+                if "value" not in item:
+                    errors.append(f"{path}.data[{i}]: PieChart item missing 'value'")
+
+    # Recurse into children
+    for i, child in enumerate(node.get("children", [])):
+        errors.extend(validate_component(child, f"{path}.children[{i}]"))
+
+    return errors
+
+
+def main():
+    try:
+        hook_input = json.load(sys.stdin)
+    except (json.JSONDecodeError, EOFError):
+        sys.exit(0)  # Can't parse input, allow
+
+    tool_input = hook_input.get("tool_input", {})
+
+    # Get content from Write or new_string from Edit
+    content = tool_input.get("content", "") or tool_input.get("new_string", "")
+    if not content:
+        sys.exit(0)
+
+    # Only validate if content contains json-render blocks
+    blocks = extract_json_render_blocks(content)
+    if not blocks:
+        sys.exit(0)
+
+    all_errors = []
+    for i, block in enumerate(blocks):
+        try:
+            tree = json.loads(block)
+        except json.JSONDecodeError as e:
+            all_errors.append(f"json-render block {i + 1}: invalid JSON — {e}")
+            continue
+        all_errors.extend(validate_component(tree, f"block[{i + 1}]"))
+
+    if all_errors:
+        msg = "Chart validation failed:\n" + "\n".join(f"  • {e}" for e in all_errors)
+        print(msg, file=sys.stderr)
+        sys.exit(2)
+
+    sys.exit(0)
+
+
+if __name__ == "__main__":
+    main()
