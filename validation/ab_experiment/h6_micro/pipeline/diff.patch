@@ -0,0 +1,207 @@
+#!/usr/bin/env python3
+"""Tests for PreToolUse validation hooks."""
+import json
+import subprocess
+import sys
+import os
+
+HOOKS_DIR = os.path.dirname(os.path.abspath(__file__))
+CHART_HOOK = os.path.join(HOOKS_DIR, "validate-chart.py")
+CONNECTOR_HOOK = os.path.join(HOOKS_DIR, "validate-connector.py")
+
+passed = 0
+failed = 0
+
+
+def run_hook(script, tool_input, tool_name="Write"):
+    """Run a hook script with the given tool input, return (exit_code, stderr)."""
+    hook_input = json.dumps({"tool_name": tool_name, "tool_input": tool_input})
+    result = subprocess.run(
+        [sys.executable, script],
+        input=hook_input,
+        capture_output=True,
+        text=True,
+        timeout=10,
+    )
+    return result.returncode, result.stderr.strip()
+
+
+def test(name, actual_code, expected_code, stderr=""):
+    global passed, failed
+    if actual_code == expected_code:
+        passed += 1
+        print(f"  PASS  {name}")
+    else:
+        failed += 1
+        print(f"  FAIL  {name} — expected exit {expected_code}, got {actual_code}")
+        if stderr:
+            print(f"        stderr: {stderr}")
+
+
+# ── Chart validation tests ───────────────────────────────────────────
+
+print("\n== validate-chart.py ==")
+
+# 1. Valid LineChart
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "content": '```json-render\n{"type":"LineChart","props":{"data":[{"d":"1","v":1}],"xKey":"d","lines":[{"key":"v"}]}}\n```',
+})
+test("valid LineChart", code, 0)
+
+# 2. Valid MetricCard in Grid
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "content": '```json-render\n{"type":"Grid","props":{"columns":2},"children":[{"type":"MetricCard","props":{"label":"Users","value":"100"}}]}\n```',
+})
+test("valid Grid with MetricCard", code, 0)
+
+# 3. Valid PieChart
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "content": '```json-render\n{"type":"PieChart","props":{"data":[{"name":"A","value":10},{"name":"B","value":20}]}}\n```',
+})
+test("valid PieChart", code, 0)
+
+# 4. Missing xKey on LineChart
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "content": '```json-render\n{"type":"LineChart","props":{"data":[{"d":"1"}],"lines":[{"key":"v"}]}}\n```',
+})
+test("missing xKey on LineChart", code, 2, err)
+
+# 5. Unknown component type
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "content": '```json-render\n{"type":"Histogram","props":{}}\n```',
+})
+test("unknown type 'Histogram'", code, 2, err)
+
+# 6. Empty data array
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "content": '```json-render\n{"type":"BarChart","props":{"data":[],"xKey":"x","bars":[{"key":"y"}]}}\n```',
+})
+test("empty data array", code, 2, err)
+
+# 7. Non-chart content (passthrough)
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/readme.md",
+    "content": "# Hello World\nJust some markdown.",
+})
+test("non-chart content passthrough", code, 0)
+
+# 8. PieChart missing name in data item
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "content": '```json-render\n{"type":"PieChart","props":{"data":[{"value":10}]}}\n```',
+})
+test("PieChart item missing name", code, 2, err)
+
+# 9. Edit tool with new_string
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "new_string": '```json-render\n{"type":"AreaChart","props":{"data":[{"d":"1","v":1}],"xKey":"d","areas":[{"key":"v"}]}}\n```',
+}, tool_name="Edit")
+test("valid AreaChart via Edit", code, 0)
+
+# 10. Grid without children
+code, err = run_hook(CHART_HOOK, {
+    "file_path": "/tmp/test.md",
+    "content": '```json-render\n{"type":"Grid","props":{"columns":3}}\n```',
+})
+test("Grid missing children", code, 2, err)
+
+
+# ── Connector validation tests ───────────────────────────────────────
+
+print("\n== validate-connector.py ==")
+
+VALID_CONNECTOR = json.dumps([{
+    "id": "semrush",
+    "name": "Semrush",
+    "specUrl": "https://api.semrush.com/openapi.json",
+    "auth": {"type": "apiKey", "paramName": "key", "in": "query"},
+    "enabled": True,
+    "custom": False,
+}])
+
+# 1. Valid connector
+code, err = run_hook(CONNECTOR_HOOK, {
+    "file_path": "/path/to/connectors.json",
+    "content": VALID_CONNECTOR,
+})
+test("valid connector config", code, 0)
+
+# 2. Missing auth.type
+code, err = run_hook(CONNECTOR_HOOK, {
+    "file_path": "/path/to/connectors.json",
+    "content": json.dumps([{
+        "id": "test", "name": "Test", "specUrl": "https://api.test.com/spec",
+        "auth": {}, "enabled": True, "custom": False,
+    }]),
+})
+test("missing auth.type", code, 2, err)
+
+# 3. Invalid auth type
+code, err = run_hook(CONNECTOR_HOOK, {
+    "file_path": "/path/to/connectors.json",
+    "content": json.dumps([{
+        "id": "test", "name": "Test", "specUrl": "https://api.test.com/spec",
+        "auth": {"type": "oauth"}, "enabled": True, "custom": False,
+    }]),
+})
+test("invalid auth type", code, 2, err)
+
+# 4. Missing required fields
+code, err = run_hook(CONNECTOR_HOOK, {
+    "file_path": "/path/to/connectors.json",
+    "content": json.dumps([{"id": "test"}]),
+})
+test("missing required fields", code, 2, err)
+
+# 5. Non-connector file (passthrough)
+code, err = run_hook(CONNECTOR_HOOK, {
+    "file_path": "/path/to/something-else.json",
+    "content": '{"foo": "bar"}',
+})
+test("non-connector file passthrough", code, 0)
+
+# 6. apiKey auth missing paramName
+code, err = run_hook(CONNECTOR_HOOK, {
+    "file_path": "/path/to/connectors.json",
+    "content": json.dumps([{
+        "id": "test", "name": "Test", "specUrl": "https://api.test.com/spec",
+        "auth": {"type": "apiKey"}, "enabled": True, "custom": False,
+    }]),
+})
+test("apiKey missing paramName", code, 2, err)
+
+# 7. header auth missing headerName
+code, err = run_hook(CONNECTOR_HOOK, {
+    "file_path": "/path/to/connectors.json",
+    "content": json.dumps([{
+        "id": "test", "name": "Test", "specUrl": "https://api.test.com/spec",
+        "auth": {"type": "header", "headerName": "X-Api-Key"},
+        "enabled": True, "custom": False,
+    }]),
+})
+test("header auth missing headerValue", code, 2, err)
+
+# 8. Invalid specUrl
+code, err = run_hook(CONNECTOR_HOOK, {
+    "file_path": "/path/to/connectors.json",
+    "content": json.dumps([{
+        "id": "test", "name": "Test", "specUrl": "not-a-url",
+        "auth": {"type": "bearer"}, "enabled": True, "custom": False,
+    }]),
+})
+test("invalid specUrl", code, 2, err)
+
+
+# ── Summary ──────────────────────────────────────────────────────────
+
+print(f"\n{'=' * 40}")
+print(f"Results: {passed} passed, {failed} failed")
+if failed > 0:
+    sys.exit(1)
