@@ -0,0 +1,111 @@
+#!/usr/bin/env python3
+"""PreToolUse hook: validate connector config before Write/Edit.
+
+Intercepts writes to connectors.json files and validates the connector
+schema: required fields, auth type constraints, etc.
+
+Exit codes:
+  0 — allow (valid connector or non-connector file)
+  2 — block with error message on stderr
+"""
+import json
+import sys
+
+VALID_AUTH_TYPES = {"apiKey", "bearer", "header"}
+
+REQUIRED_FIELDS = ["id", "name", "specUrl", "auth", "enabled"]
+
+AUTH_REQUIREMENTS = {
+    "apiKey": ["paramName"],
+    "bearer": [],
+    "header": ["headerName", "headerValue"],
+}
+
+
+def validate_connector(conn, index):
+    """Validate a single connector config object."""
+    errors = []
+    prefix = f"connector[{index}]"
+
+    if not isinstance(conn, dict):
+        errors.append(f"{prefix}: expected object, got {type(conn).__name__}")
+        return errors
+
+    # Check required fields
+    for field in REQUIRED_FIELDS:
+        if field not in conn:
+            errors.append(f"{prefix}: missing required field '{field}'")
+
+    conn_name = conn.get("name", conn.get("id", f"index {index}"))
+
+    # Validate auth block
+    auth = conn.get("auth")
+    if auth is not None:
+        if not isinstance(auth, dict):
+            errors.append(f"{prefix} ({conn_name}): 'auth' must be an object")
+        else:
+            auth_type = auth.get("type")
+            if not auth_type:
+                errors.append(f"{prefix} ({conn_name}): auth missing 'type'")
+            elif auth_type not in VALID_AUTH_TYPES:
+                errors.append(
+                    f"{prefix} ({conn_name}): invalid auth type '{auth_type}'. "
+                    f"Valid: {', '.join(sorted(VALID_AUTH_TYPES))}"
+                )
+            else:
+                for req in AUTH_REQUIREMENTS.get(auth_type, []):
+                    if not auth.get(req):
+                        errors.append(
+                            f"{prefix} ({conn_name}): auth type '{auth_type}' "
+                            f"requires '{req}'"
+                        )
+
+    # Validate specUrl is a URL-like string
+    spec_url = conn.get("specUrl", "")
+    if spec_url and not (spec_url.startswith("http://") or spec_url.startswith("https://")):
+        errors.append(f"{prefix} ({conn_name}): specUrl must start with http:// or https://")
+
+    return errors
+
+
+def main():
+    try:
+        hook_input = json.load(sys.stdin)
+    except (json.JSONDecodeError, EOFError):
+        sys.exit(0)
+
+    tool_input = hook_input.get("tool_input", {})
+    file_path = tool_input.get("file_path", "")
+
+    # Only validate connectors.json files
+    if not file_path.endswith("connectors.json"):
+        sys.exit(0)
+
+    # Get content from Write or new_string from Edit
+    content = tool_input.get("content", "") or tool_input.get("new_string", "")
+    if not content:
+        sys.exit(0)
+
+    try:
+        data = json.loads(content)
+    except json.JSONDecodeError as e:
+        print(f"Connector validation failed: invalid JSON — {e}", file=sys.stderr)
+        sys.exit(2)
+
+    # Handle both array and single-object formats
+    connectors = data if isinstance(data, list) else [data]
+
+    all_errors = []
+    for i, conn in enumerate(connectors):
+        all_errors.extend(validate_connector(conn, i))
+
+    if all_errors:
+        msg = "Connector validation failed:\n" + "\n".join(f"  • {e}" for e in all_errors)
+        print(msg, file=sys.stderr)
+        sys.exit(2)
+
+    sys.exit(0)
+
+
+if __name__ == "__main__":
+    main()
