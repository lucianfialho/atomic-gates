{
  "description": "Quality gates for autonomous development pipeline",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/lib/runner.py",
            "timeout": 30,
            "statusMessage": "gates runner..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/lib/gate_metadata.py",
            "timeout": 30,
            "statusMessage": "Checking .metadata/ before commit..."
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/lib/gate_pr_structure.py",
            "timeout": 30,
            "statusMessage": "Checking PR structure before create..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/lib/gate_role.py",
            "timeout": 15,
            "statusMessage": "Checking role scope..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-tests.sh",
            "timeout": 120,
            "statusMessage": "Running quality gates..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-build.sh",
            "timeout": 120,
            "statusMessage": "Verifying build..."
          }
        ]
      }
    ]
  }
}
